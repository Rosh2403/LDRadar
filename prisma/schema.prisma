generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Finding {
  id          String   @id @default(cuid())
  institution String
  type        String
  title       String
  summary     String
  category    String
  date        String
  sourceUrl   String
  scannedAt   DateTime @default(now())

  @@unique([institution, title])
  @@index([scannedAt(sort: Desc)])
  @@index([category])
  @@index([type])
}

model ScanRun {
  id             String    @id @default(cuid())
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  status         String
  sourcesScanned Int       @default(0)
  findingsCount  Int       @default(0)

  @@index([status, completedAt(sort: Desc)])
}

model CustomSource {
  id      String   @id @default(cuid())
  name    String
  url     String   @unique
  type    String   @default("Other")
  addedAt DateTime @default(now())
}
